# Helicyn public Supabase config -- names kept consistent with common
# bundler conventions in case this static site is ever migrated to
# Vite/Next. The current static site does NOT read these directly; it
# reads window.HELICYN_SUPABASE_URL / window.HELICYN_SUPABASE_ANON_KEY
# from supabase-config.js instead (copy supabase-config.example.js).
# See docs/auth_setup.md.
#
# These are PUBLIC values (protected by Supabase Row Level Security),
# never the service role / secret key.

# Vite-style naming
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Next.js-style naming (equivalent, for reference)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
